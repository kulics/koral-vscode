{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Koral",
  "scopeName": "source.koral",
  "foldingStartMarker": "^\\s*(?:/\\*|//\\s*#?region\\b|(?:let|type|given|using|if|when|while|for)\\b.*\\{\\s*$|\\{\\s*$)",
  "foldingStopMarker": "^\\s*(?:\\*/|//\\s*#?endregion\\b|\\})\\s*$",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#implicit-member" },
    { "include": "#constants" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.koral",
          "begin": "//",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.koral" } },
          "end": "$\\n?"
        },
        {
          "name": "comment.block.koral",
          "begin": "/\\*",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.begin.koral" } },
          "end": "\\*/",
          "endCaptures": { "0": { "name": "punctuation.definition.comment.end.koral" } }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.koral",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": [
            { "name": "constant.character.escape.koral", "match": "\\\\(?:[ntrfv0\\\\\"']|x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f]+\\})" },
            {
              "name": "meta.interpolation.koral",
              "begin": "\\\\\\(",
              "end": "\\)",
              "patterns": [{ "include": "$self" }]
            }
          ]
        },
        {
          "name": "string.quoted.double.koral",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.koral", "match": "\\\\(?:[ntrfv0\\\\\"']|x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f]+\\})" },
            {
              "name": "meta.interpolation.koral",
              "begin": "\\\\\\(",
              "end": "\\)",
              "patterns": [{ "include": "$self" }]
            }
          ]
        },
        {
          "name": "string.quoted.single.koral",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "name": "constant.character.escape.koral", "match": "\\\\(?:[ntrfv0\\\\\"']|x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f]+\\})" }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.duration.koral",
          "match": "\\b\\d[\\d_]*(?:h|min|ms|us|ns|s)\\b"
        },
        {
          "name": "constant.numeric.float.koral",
          "match": "\\b\\d[\\d_]*(?:\\.\\d[\\d_]*)?(?:[eE][+\\-]?\\d[\\d_]*)\\b"
        },
        {
          "name": "constant.numeric.float.koral",
          "match": "\\b\\d[\\d_]*\\.\\d[\\d_]*\\b"
        },
        {
          "name": "constant.numeric.binary.koral",
          "match": "\\b0b[01_]+\\b"
        },
        {
          "name": "constant.numeric.octal.koral",
          "match": "\\b0o[0-7_]+\\b"
        },
        {
          "name": "constant.numeric.hex.koral",
          "match": "\\b0x[0-9A-Fa-f_]+\\b"
        },
        {
          "name": "constant.numeric.integer.koral",
          "match": "\\b\\d[\\d_]*\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "comment": "compound keywords: and then, or else",
          "name": "keyword.operator.word.koral",
          "match": "\\b(?:and\\s+then|or\\s+else)\\b"
        },
        {
          "name": "keyword.control.koral",
          "match": "\\b(?:if|then|else|when|while|for|break|continue|return|yield|finally|is|in)\\b"
        },
        {
          "comment": "word operators",
          "name": "keyword.operator.word.koral",
          "match": "\\b(?:and|or|not|ref|deref|ptr)\\b"
        },
        {
          "name": "keyword.declaration.koral",
          "match": "\\b(?:let|mut|type|trait|given|using|public|private|protected|foreign|intrinsic|as)\\b"
        },
        {
          "name": "variable.language.koral",
          "match": "\\b(?:self|Super|Self)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.builtin.koral",
          "match": "\\b(?:Int|UInt|Int8|UInt8|Int16|UInt16|Int32|UInt32|Int64|UInt64|Float32|Float64|Bool|String|Void|Rune|Option|Result|List|Map|Set|Func)\\b"
        },
        {
          "comment": "postfix type modifiers: Int ref, [Int]List ref, [Int ref]Option ref",
          "name": "meta.type.postfix-modifier.koral",
          "match": "(?:\\]|\\b[A-Z][A-Za-z0-9_]*)\\s+(weakref|ref|ptr)\\b",
          "captures": {
            "1": { "name": "storage.modifier.type.koral" }
          }
        },
        {
          "name": "entity.name.type.koral",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.declaration.koral",
          "match": "\\b(let)\\s+(\\[[^\\]]*\\])?\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "keyword.declaration.function.koral" },
            "2": { "name": "meta.generic-params.koral" },
            "3": { "name": "entity.name.function.koral" }
          }
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.koral",
          "match": "\\b(?:true|false)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.range.koral",
          "match": "\\.\\.\\.\\.|<\\.\\.\\.|\\.\\.\\.<|<\\.\\.<|\\.\\.<|<\\.\\.|\\.\\.\\.|\\.\\.(?![.])"
        },
        {
          "name": "keyword.operator.arrow.koral",
          "match": "->"
        },
        {
          "name": "keyword.operator.assignment.koral",
          "match": "<<=|>>=|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|(?<![=<>!])=(?!=)"
        },
        {
          "name": "keyword.operator.comparison.koral",
          "match": "==|<>|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.bitwise.koral",
          "match": "<<|>>|[&|^~]"
        },
        {
          "name": "keyword.operator.arithmetic.koral",
          "match": "[+\\-*/%]"
        },
        {
          "name": "punctuation.separator.koral",
          "match": "[,;:]"
        },
        {
          "name": "punctuation.accessor.koral",
          "match": "(?<=[A-Za-z0-9_\\]\\)])\\."
        }
      ]
    }
  }
}
