{
  "comments": {
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "indentationRules": {
    "increaseIndentPattern": "^((?!//).)*(\\{[^\\}\"']*|\\([^\\)\\\"']*|\\[[^\\]\\\"']*)$",
    "decreaseIndentPattern": "^\\s*[\\)\\]\\}].*$"
  },
  "folding": {
    "markers": {
      "start": "^\\s*//\\s*#?region\\b",
      "end": "^\\s*//\\s*#?endregion\\b"
    }
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "/*", "close": "*/", "notIn": ["string"] },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "onEnterRules": [
    {
      "beforeText": "/\\*\\*(?!/)([^\\*]|\\*(?!/))*$",
      "afterText": "^\\s*\\*/$",
      "action": { "indent": "indentOutdent", "appendText": " * " }
    },
    {
      "beforeText": "/\\*\\*(?!/)([^\\*]|\\*(?!/))*$",
      "action": { "indent": "none", "appendText": " * " }
    },
    {
      "beforeText": "^\\s* \\*[^/]*$",
      "action": { "indent": "none", "appendText": "* " }
    },
    {
      "beforeText": "^\\s*\\*/$",
      "action": { "indent": "none", "removeText": 1 }
    }
  ]
}
